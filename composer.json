{
    "name": "arris/composer-proxy",
    "authors": [
        {
            "name": "karelwintersky",
            "email": "karel@wintersky.ru"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "platform": {
            "php": "8.2"
        },
        "optimize-autoloader": true,
        "classmap-authoritative": true
    },
    "require": {
        "php": "^8.2",
        "ext-pcntl": "*",
        "amphp/amp": "^3",
        "amphp/http-server": "^3",
        "amphp/http-server-router": "^2",
        "amphp/http-client": "^5",
        "amphp/file": "^3",
        "amphp/socket": "^2.4",
        "ext-pdo": "*"
    }
}
